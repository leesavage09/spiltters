generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String      @id @default(cuid())
  email     String      @unique
  username  String?     @db.VarChar(30)
  password  String
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")
  splits              SplitUser[]
  expenses            Expense[]
  expenseShares       ExpenseShare[]
  sentInvitations     Invitation[]   @relation("SentInvitations")
  receivedInvitations Invitation[]   @relation("ReceivedInvitations")
  notifications       Notification[]

  @@map("users")
}

model Split {
  id        String      @id @default(cuid())
  name      String      @db.VarChar(50)
  emoji     String      @db.VarChar(10)
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")
  users       SplitUser[]
  expenses    Expense[]
  invitations Invitation[]

  @@map("splits")
}

model SplitUser {
  splitId   String   @map("split_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  split     Split    @relation(fields: [splitId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@id([splitId, userId])
  @@map("split_users")
}

model Expense {
  id        String         @id @default(cuid())
  title     String         @db.VarChar(200)
  amount    Int
  currency  String         @db.VarChar(3)
  date      DateTime
  splitId   String         @map("split_id")
  paidById  String         @map("paid_by_id")
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")
  split     Split          @relation(fields: [splitId], references: [id])
  paidBy    User           @relation(fields: [paidById], references: [id])
  shares    ExpenseShare[]

  @@map("expenses")
}

model ExpenseShare {
  id        String  @id @default(cuid())
  expenseId String  @map("expense_id")
  userId    String  @map("user_id")
  amount    Int
  expense   Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id])

  @@unique([expenseId, userId])
  @@map("expense_shares")
}

model Invitation {
  id         String   @id @default(cuid())
  senderId   String   @map("sender_id")
  receiverId String   @map("receiver_id")
  splitId    String   @map("split_id")
  createdAt  DateTime @default(now()) @map("created_at")
  sender     User     @relation("SentInvitations", fields: [senderId], references: [id])
  receiver   User     @relation("ReceivedInvitations", fields: [receiverId], references: [id])
  split      Split    @relation(fields: [splitId], references: [id])

  @@unique([receiverId, splitId])
  @@map("invitations")
}

model Notification {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  title     String    @db.VarChar(100)
  message   String    @db.VarChar(500)
  type      String    @db.VarChar(50)
  entityId  String    @map("entity_id")
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id])

  @@map("notifications")
}
