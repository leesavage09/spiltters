    "/api/splits": {
      "get": {
        "operationId": "SplitsController_findAll",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/SplitResponseDto"
                  }
                }
              }
            }
          }
        },
        "summary": "List current user splits",
        "tags": [
          "splits"
        ]
      },
      "post": {
        "operationId": "SplitsController_create",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateSplitDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SplitResponseDto"
                }
              }
            }
          }
        },
        "summary": "Create a new split",
        "tags": [
          "splits"
        ]
      }
    },
    "/api/splits/{id}": {
      "patch": {
        "operationId": "SplitsController_update",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateSplitDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SplitResponseDto"
                }
              }
            }
          }
        },
        "summary": "Update a split",
        "tags": [
          "splits"
        ]
      },
      "delete": {
        "operationId": "SplitsController_delete",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageResponseDto"
                }
              }
            }
          }
        },
        "summary": "Delete a split",
        "tags": [
          "splits"
        ]
      }
    },
    "/api/splits/{splitId}/expenses": {
      "get": {
        "operationId": "ExpensesController_findBySplit",
        "parameters": [
          {
            "name": "splitId",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "skip",
            "required": false,
            "in": "query",
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "take",
            "required": false,
            "in": "query",
            "schema": {
              "type": "number"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedExpensesResponseDto"
                }
              }
            }
          }
        },
        "summary": "List expenses for a split",
        "tags": [
          "expenses"
        ]
      },
      "post": {
        "operationId": "ExpensesController_create",
        "parameters": [
          {
            "name": "splitId",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateExpenseDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExpenseResponseDto"
                }
              }
            }
          }
        },
        "summary": "Create an expense in a split",
        "tags": [
          "expenses"
        ]
      }
    }
  },
  "info": {
    "title": "Splitters API",
    "description": "",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "schemas": {
      "HealthResponseDto": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          }
        },
        "required": [
          "status"
        ]
      },
      "RegisterDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "password": {
            "type": "string",
            "minLength": 8
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "AuthResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "email": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "email"
        ]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "MessageResponseDto": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          }
        },
        "required": [
          "message"
        ]
      },
      "SplitUserResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "email": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "email"
        ]
      },
      "SplitResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "emoji": {
            "type": "string"
          },
          "users": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SplitUserResponseDto"
            }
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "id",
          "name",
          "emoji",
          "users",
          "createdAt",
          "updatedAt"
        ]
      },
      "CreateSplitDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Friday Dinner",
            "maxLength": 50
          },
          "emoji": {
            "type": "string",
            "example": "🍕"
          }
        },
        "required": [
          "name",
          "emoji"
        ]
      },
      "UpdateSplitDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Friday Dinner",
            "maxLength": 50
          },
          "emoji": {
            "type": "string",
            "example": "🍕"
          }
        }
      },
      "ExpensePaidByResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "email": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "email"
        ]
      },
      "ExpenseShareResponseDto": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "amount": {
            "type": "number",
            "description": "Amount in pence/cents"
          }
        },
        "required": [
          "userId",
          "email",
          "amount"
        ]
      },
      "ExpenseResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "amount": {
            "type": "number",
            "description": "Total amount in pence/cents"
          },
          "currency": {
            "type": "string"
          },
          "date": {
            "format": "date-time",
            "type": "string"
          },
          "paidBy": {
            "$ref": "#/components/schemas/ExpensePaidByResponseDto"
          },
          "shares": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ExpenseShareResponseDto"
            }
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "id",
          "title",
          "amount",
          "currency",
          "date",
          "paidBy",
          "shares",
          "createdAt",
          "updatedAt"
        ]
      },
      "PaginatedExpensesResponseDto": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ExpenseResponseDto"
            }
          },
          "total": {
            "type": "number"
          },
          "hasMore": {
            "type": "boolean"
          }
        },
        "required": [
          "items",
          "total",
          "hasMore"
        ]
      },
      "ExpenseShareDto": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string",
            "example": "clxyz123"
          },
          "amount": {
            "type": "number",
            "example": 1250,
            "description": "Amount in pence/cents"
          }
        },
        "required": [
          "userId",
          "amount"
        ]
      },
      "CreateExpenseDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "example": "Friday dinner",
            "maxLength": 200
          },
          "amount": {
            "type": "number",
            "example": 1250,
            "description": "Total amount in pence/cents"
          },
          "currency": {
            "type": "string",
            "example": "GBP",
            "enum": [
              "GBP",
              "EUR",
              "USD"
            ]
          },
          "date": {
            "type": "string",
            "example": "2026-03-01T12:00:00.000Z"
          },
          "paidBy": {
            "type": "string",
            "example": "clxyz123",
            "description": "User ID of who paid"
          },
          "shares": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ExpenseShareDto"
            }
          }
        },
        "required": [
          "title",
          "amount",
          "currency",
          "date",
          "paidBy",
          "shares"
        ]
      }
    }
  }
}